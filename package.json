{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "concurrently \"vite\" \"php artisan serve --host 0.0.0.0 --port 8000\"",
        "prod": "npm run build && php artisan serve --host 0.0.0.0 --port 8000",
        "share": "npm run build && php artisan serve --host 0.0.0.0 --port 8000"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "alpinejs": "^3.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-echo": "^2.3.4",
        "laravel-vite-plugin": "^2.0.0",
        "pusher-js": "^8.5.0",
        "tailwindcss": "^4.2.2",
        "vite": "^7.0.7"
    }
}
